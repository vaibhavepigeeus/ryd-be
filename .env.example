# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ENVIRONMENT=DEVELOPMENT

# Database
DATABASE_NAME=ryd_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1

# Email / SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=
SMTP_USERNAME=
SMTP_PASSWORD=

# IMAP (email list / reply)
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_EMAIL_USER=
IMAP_EMAIL_PASS=
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Azure AD SSO
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=
AZURE_SCOPE=openid profile email

# Encryption (user email encryption)
ENCRYPTION_KEY=ryd-dev-encryption-key-32chars!!

# AWS S3 (documents / file management)
USE_S3=False
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_PROCESSED_BUCKET=
TEMP_FILES_PATH=/tmp/ryd_uploads

# Redis (WebSocket notifications)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Cookies (set True in production behind HTTPS)
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
